# Agent Registry API Configuration
REACT_APP_API_GATEWAY_URL=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com/prod
REACT_APP_AWS_REGION=us-east-1
REACT_APP_IDENTITY_POOL_ID=us-east-1:your-identity-pool-id

# Optional: For development/testing without AWS authentication
# Leave REACT_APP_IDENTITY_POOL_ID empty to disable AWS authentication